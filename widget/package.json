{
  "name": "@gluu/chat-widget",
  "version": "0.1.0",
  "description": "Floating, embeddable React chat widget for the Gluu AI Assistant.",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "demo": "npm --prefix example install && npm --prefix example run dev"
  },
  "keywords": [
    "gluu",
    "chatbot",
    "widget",
    "react",
    "rag",
    "assistant"
  ],
  "license": "MIT",
  "peerDependencies": {
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  },
  "devDependencies": {
    "tsup": "^8.0.0",
    "typescript": "^5.3.3"
  },
  "dependencies": {
    "@types/react": "^19.2.16",
    "@types/react-dom": "^19.2.3"
  }
}
