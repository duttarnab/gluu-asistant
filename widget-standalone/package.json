{
  "name": "@gluu/chat-widget-standalone",
  "version": "0.1.0",
  "description": "Self-contained floating React chat widget for Gluu: baked-in vector index + Ollama, no server.",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": ["dist", "src"],
  "sideEffects": false,
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "export-index": "tsx scripts/export-index.ts",
    "demo": "npm --prefix example install && npm --prefix example run dev"
  },
  "keywords": ["gluu", "chatbot", "widget", "react", "rag", "ollama", "browser-extension", "offline"],
  "license": "MIT",
  "peerDependencies": {
    "react": ">=17",
    "react-dom": ">=17"
  },
  "devDependencies": {
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "chromadb": "^1.10.5",
    "dotenv": "^16.4.5",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "tsup": "^8.0.0",
    "tsx": "^4.7.0",
    "typescript": "^5.3.3"
  }
}
